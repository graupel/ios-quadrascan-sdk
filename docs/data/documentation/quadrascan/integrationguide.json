png","traits":["2x","light"]}],"type":"image"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanResponse/cancelled":{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/cancelled","kind":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancelled","kind":"identifier"}],"role":"symbol","url":"\/documentation\/quadrascan\/quadrascanresponse\/cancelled","abstract":[],"title":"QuadrascanResponse.cancelled","type":"topic"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan":{"kind":"symbol","url":"\/documentation\/quadrascan","abstract":[{"type":"text","text":"Generate 3D models and anthropometric measurements from body scans."}],"images":[{"type":"icon","identifier":"logo.png"}],"role":"collection","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan","type":"topic","title":"Quadrascan"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanFlow/photoPicker":{"role":"symbol","abstract":[],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"photoPicker"}],"type":"topic","title":"QuadrascanFlow.photoPicker","kind":"symbol","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/photoPicker","url":"\/documentation\/quadrascan\/quadrascanflow\/photopicker"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanResponse/success(_:)":{"title":"QuadrascanResponse.success(_:)","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"success","kind":"identifier"},{"text":"(","kind":"text"},{"text":"QuadrascanResult","kind":"typeIdentifier","preciseIdentifier":"s:10Quadrascan0A6ResultV"},{"text":")","kind":"text"}],"abstract":[],"type":"topic","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/success(_:)","kind":"symbol","url":"\/documentation\/quadrascan\/quadrascanresponse\/success(_:)","r