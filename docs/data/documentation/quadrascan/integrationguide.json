/Quadrascan"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanFlow/measurementOnly(usdzURL:heightInInches:weightInPounds:)":{"kind":"symbol","abstract":[],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"measurementOnly","kind":"identifier"},{"text":"(","kind":"text"},{"text":"usdzURL","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10Foundation3URLV","text":"URL","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"heightInInches","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"weightInPounds","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"role":"symbol","type":"topic","url":"\/documentation\/quadrascan\/quadrascanflow\/measurementonly(usdzurl:heightininches:weightinpounds:)","title":"QuadrascanFlow.measurementOnly(usdzURL:heightInInches:weightInPounds:)","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/measurementOnly(usdzURL:heightInInches:weightInPounds:)"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanAppearance":{"url":"\/documentation\/quadrascan\/quadrascanappearance","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"QuadrascanAppearance","kind":"identifier"}],"navigatorTitle":[{"text":"QuadrascanAppearance","kind":"identifier"}],"title":"QuadrascanAppearance","abstract":[{"type":"text","text":"UI appearance configuration applied to the Quadrascan workflow."}]},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanResponse/success(_:)":{"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"success"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"QuadrascanResult","preciseIdentifier":"s:10Quadrascan0A6ResultV"},{"kind":"text","text":")"}],"abstract":[],"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/success(_:)","title":"QuadrascanResponse.success(_:)","type":"topic","kind":"symbol","url":"\/documentation\/quadrascan\/quadrascanresponse\/success(_:)","role":"symbol"}}}