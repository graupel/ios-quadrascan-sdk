{"metadata":{"title":"Integration Guide","images":[{"identifier":"greenhand.png","type":"card"}],"roleHeading":"Article","color":{"standardColorIdentifier":"purple"},"platforms":[{"introducedAt":"17.0","beta":false,"name":"iOS"}],"role":"article","modules":[{"name":"Quadrascan"}]},"kind":"article","identifier":{"url":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Integrate Quadrascan to generate 3D models and anthropometric measurements of a subject using a guided, SwiftUI-based scanning flow."}],"hierarchy":{"paths":[["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan"]]},"sampleCodeDownload":{"action":{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/graupel\/ios-quadrascan-sdk","overridingTitle":"Visit"},"kind":"sampleDownload"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"aside","name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This SDK is in alpha. Documentation and APIs are subject to change."}]}]},{"type":"paragraph","inlineContent":[{"text":"Quadrascan SDK exposes a SwiftUI view that interactively guides a person through a process that collects images of them and returns a 3D model and anthropometric measurements of said person. To use the SDK, add it to your project, provide a configuration, and present the scan view. The scan completes with a result object containing output based on your configuration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"system_overview","type":"image"}]},{"text":"App Permissions","type":"heading","level":2,"anchor":"App-Permissions"},{"inlineContent":[{"type":"text","text":"Quadrascan requires camera and photo library access. Add these keys to your app’s Info.plist:"}],"type":"paragraph"},{"code":["<key>NSCameraUsageDescription<\/key>","<string>Required for body scan capture<\/string>","<key>NSPhotoLibraryUsageDescription<\/key>","<string>Required for body scan capture<\/string>"],"syntax":"xml","type":"codeListing"},{"content":[{"inlineContent":[{"text":"Both keys are required for app submission.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"text":"Adding the SDK to your App","type":"heading","level":2,"anchor":"Adding-the-SDK-to-your-App"},{"text":"Using Swift Package Manager","type":"heading","level":3,"anchor":"Using-Swift-Package-Manager"},{"inlineContent":[{"text":"Add Quadrascan to your ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["dependencies: [","    .package(url: \"https:\/\/github.com\/graupel\/ios-quadrascan-sdk.git\", .branch(\"main\"))","]"],"syntax":"swift","type":"codeListing"},{"text":"Manual Installation","type":"heading","level":3,"anchor":"Manual-Installation"},{"inlineContent":[{"type":"text","text":"You can integrate the SDK manually from the GitHub Releases page."}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Download "},{"type":"codeVoice","code":"Quadrascan-x.x.x.xcframework.zip"},{"type":"text","text":" from the "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/graupel\/ios-quadrascan-sdk\/releases"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Uncompress the zip file and then move the "},{"type":"codeVoice","code":"Quadrascan-x.x.x.xcframework"},{"type":"text","text":" artifact into your project folder."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Open your app’s project file in Xcode and then select your app’s target under target list.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Add ","type":"text"},{"code":"Quadrascan-x.x.x.xcframework","type":"codeVoice"},{"text":" to the “Frameworks, Libraries, and Embedded Content” section in the General tab of your iOS app target, and select “Embed & Sign”.","type":"text"}],"type":"paragraph"}]}]},{"text":"SDK Initialization","type":"heading","level":2,"anchor":"SDK-Initialization"},{"inlineContent":[{"type":"text","text":"Import the SDK and create a configuration:"}],"type":"paragraph"},{"code":["import Quadrascan","","let config = try QuadrascanConfiguration(teamID: \"YOUR_TEAM_ID\",","                                         meshGenerationServiceToken: \"YOUR_MESH_TOKEN\",","                                         measurementServiceToken: \"YOUR_MEASUREMENT_TOKEN\", \/\/ Required if requesting measurements","                                         requestedOutput: [.stlMesh, .measurements]) \/\/ or [.stlMesh], or [.usdzModel], or [.objMesh], or [.usdzModel, .measurements] or [.objMesh, .measurements]"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Present "},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","type":"reference","isActive":true},{"type":"text","text":" in your SwiftUI hierarchy. Handle the result in the provided closure:"}],"type":"paragraph"},{"code":["QuadrascanView(configuration: config) { response in","    \/\/ Handle session result here","}"],"syntax":"swift","type":"codeListing"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"teamID"},{"text":", ","type":"text"},{"type":"codeVoice","code":"meshGenerationServiceToken"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"measurementServiceToken"},{"text":" are provided by Fitmatch.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"meshGenerationServiceToken"},{"text":" is required for guided capture and photo picker flows.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"measurementServiceToken","type":"codeVoice"},{"text":" is required when ","type":"text"},{"code":"requestedOutput","type":"codeVoice"},{"text":" includes ","type":"text"},{"code":".measurements","type":"codeVoice"},{"text":", and for measurement-only flow.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Set "},{"type":"codeVoice","code":"requestedOutput"},{"type":"text","text":" to specify which results you need. Use "},{"type":"codeVoice","code":"[.usdzModel, .measurements]"},{"type":"text","text":", "},{"type":"codeVoice","code":"[.stlMesh, .measurements]"},{"type":"text","text":" or "},{"type":"codeVoice","code":"[.objMesh, .measurements]"},{"type":"text","text":" to request both a 3D model and anthropometric measurements."}],"type":"paragraph"}]}]},{"content":[{"inlineContent":[{"text":"The configuration initializer throws an error if required tokens are missing or invalid. It also throws an error if an invalid combination of ","type":"text"},{"code":"requestedOutput","type":"codeVoice"},{"text":" is provided. An example of an invalid combination would be any combination that includes more than one 3d type output. e.g. [.stlMesh, .usdzModel], [.objMesh, .usdzModel], or [.objMesh, .stlMesh]. Only one 3D model format can be specified at a time. Wrap the initialization in a ","type":"text"},{"code":"do-catch","type":"codeVoice"},{"text":" block or use ","type":"text"},{"code":"try?","type":"codeVoice"},{"text":" for error handling.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"text":"Optional Configuration","type":"heading","level":3,"anchor":"Optional-Configuration"},{"inlineContent":[{"text":"The configuration supports several optional parameters to customize the scanning experience:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"flow","type":"codeVoice"}],"type":"strong"},{"text":": Choose the entry point for the workflow. Use ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/guidedCapture","isActive":true,"type":"reference"},{"text":" (default) to start with AI-guided camera capture, ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/cameraCapture","isActive":true,"type":"reference"},{"text":" to start with manual back-camera 4-pose capture, ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/photoPicker","isActive":true,"type":"reference"},{"text":" to start with photo library selection, or ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/measurementOnly(usdzURL:heightInInches:weightInPounds:sessionContext:)","isActive":true,"type":"reference"},{"text":" to start directly at measurement generation with a USDZ model.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":"shouldShowWeightInput","type":"codeVoice"}],"type":"strong"},{"text":": When ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", displays a weight entry field during the flow. Defaults to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"shouldUseImperialUnits","type":"codeVoice"}],"type":"strong"},{"type":"text","text":": When "},{"code":"true","type":"codeVoice"},{"type":"text","text":", uses feet\/inches and pounds throughout the UI. When "},{"code":"false","type":"codeVoice"},{"type":"text","text":" (default), uses centimeters and kilograms."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"appearance"}]},{"type":"text","text":": Customize the UI accent color with a "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","isActive":true},{"type":"text","text":" object. Set the "},{"type":"codeVoice","code":"accentColor"},{"type":"text","text":" to match your app’s design, which affects buttons and highlights throughout the scan workflow."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"logLevelThreshold","type":"codeVoice"}],"type":"strong"},{"text":": Control debug logging verbosity using ","type":"text"},{"code":"OSLogType","type":"codeVoice"},{"text":". Defaults to ","type":"text"},{"code":".error","type":"codeVoice"},{"text":". Set to ","type":"text"},{"code":".debug","type":"codeVoice"},{"text":" or ","type":"text"},{"code":".info","type":"codeVoice"},{"text":" for more detailed logging during development.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"clientUserID"}]},{"type":"text","text":": Optional user identifier for associating scans with users in your system. Used for analytics and support purposes."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"telemetryEnabled","type":"codeVoice"}],"type":"strong"},{"text":": Controls whether anonymized diagnostic telemetry is sent. Defaults to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}]}]}]},{"inlineContent":[{"text":"On completion, the response indicates success, failure, or user cancellation.","type":"text"}],"type":"paragraph"},{"text":"Complete Example","type":"heading","level":2,"anchor":"Complete-Example"},{"inlineContent":[{"text":"Here’s a complete example showing how to integrate Quadrascan into a SwiftUI view:","type":"text"}],"type":"paragraph"},{"code":["import SwiftUI","import Quadrascan","import AVFoundation","import Photos","","struct MyView: View {","    @State private var showingScanView = false","    @State private var showingPermissionAlert = false","","    var body: some View {","        Button(\"Start Body Scan\") {","            Task {","                if await requestPermissions() {","                    showingScanView = true","                } else {","                    showingPermissionAlert = true","                }","            }","        }","        .fullScreenCover(isPresented: $showingScanView) {","            scanView","        }","        .alert(\"Permissions Required\", isPresented: $showingPermissionAlert) {","            Button(\"OK\") { }","        } message: {","            Text(\"Camera and photo library access are required for body scanning.\")","        }","    }","","    @ViewBuilder","    private var scanView: some View {","        \/\/ In production, handle configuration errors appropriately for your app","        if let config = try? QuadrascanConfiguration(teamID: \"YOUR_TEAM_ID\",","                                                     meshGenerationServiceToken: \"YOUR_MESH_TOKEN\",","                                                     measurementServiceToken: \"YOUR_MEASUREMENT_TOKEN\",","                                                     requestedOutput: [.usdzModel, .measurements],","                                                     appearance: QuadrascanAppearance(accentColor: .blue),","                                                     shouldShowWeightInput: true,","                                                     shouldUseImperialUnits: false) {","            QuadrascanView(configuration: config) { response in","                handleResponse(response)","            }","        } else {","            Text(\"Configuration error\")","        }","    }","","    private func handleResponse(_ response: QuadrascanResponse) {","        switch response {","        case .success(let result):","            print(\"Height: \\(result.heightInInches) inches, Weight: \\(result.weightInPounds, default: \"N\/A\") lbs\")","            if let measurements = result.measurementResult?.measurements {","                print(\"Received measurements: \\(measurements)\")","            }","            if let modelData = result.modelData {","                print(\"Received 3D model: \\(modelData.count) bytes\")","            }","        case .failure(let error):","            print(\"Scan failed: \\(error.localizedDescription)\")","        case .cancelled:","            break","        @unknown default:","            break","        }","        showingScanView = false","    }","","    private func requestPermissions() async -> Bool {","        let cameraAuthorized = await requestCameraAuthorization()","        let photoLibraryAuthorized = await requestPhotoLibraryAuthorization()","        return cameraAuthorized && photoLibraryAuthorized","    }","","    private func requestCameraAuthorization() async -> Bool {","        let status = AVCaptureDevice.authorizationStatus(for: .video)","        if status == .authorized { return true }","        if status == .notDetermined { return await AVCaptureDevice.requestAccess(for: .video) }","        return false","    }","","    private func requestPhotoLibraryAuthorization() async -> Bool {","        let status = PHPhotoLibrary.authorizationStatus(for: .readWrite)","        if status == .authorized || status == .limited { return true }","        if status == .notDetermined {","            let newStatus = await PHPhotoLibrary.requestAuthorization(for: .readWrite)","            return newStatus == .authorized || newStatus == .limited","        }","        return false","    }","}"],"syntax":"swift","type":"codeListing"},{"text":"Handling Completion and Errors","type":"heading","level":2,"anchor":"Handling-Completion-and-Errors"},{"inlineContent":[{"text":"Handling the result from ","type":"text"},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","isActive":true},{"text":" might look like the following:","type":"text"}],"type":"paragraph"},{"code":["QuadrascanView(configuration: config) { response in","    switch response {","    case .success(let result):","        \/\/ Calibration inputs are always available","        print(\"Height: \\(result.heightInInches) inches, Weight: \\(result.weightInPounds, default: \"N\/A\") lbs\")","        if let measurements = result.measurementResult?.measurements {","            \/\/ Process measurements data","        }","        if let modelData = result.modelData {","            \/\/ Process 3D model data","        }","        \/\/ Access metadata: result.metadata","    case .failure(let error):","        switch error {","        case .captureError(let underlying):","            \/\/ Camera or capture issues occurred","        case .meshGenerationError(let underlying):","            \/\/ Mesh generation service failure","        case .meshProcessingError(let underlying):","            \/\/ Model processing failure","        case .measurementGenerationError(let underlying):","            \/\/ Measurement service failure","        case .configurationError(let underlying):","            \/\/ Invalid configuration (e.g., missing tokens)","        }","    case .cancelled:","        \/\/ User cancelled the flow","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"On "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/success(_:)","isActive":true},{"text":", handle the ","type":"text"},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult","isActive":true},{"text":" according to your needs. It is appropriate to remove the ","type":"text"},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","isActive":true},{"text":" from the view hierarchy at this point.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/cancelled","isActive":true},{"type":"text","text":" the user aborted the flow; reset your UI or state as appropriate."}],"type":"paragraph"},{"inlineContent":[{"text":"On ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/failure(_:)"},{"text":", handle the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError"},{"text":" value.","type":"text"}],"type":"paragraph"},{"text":"Flow Customizations","type":"heading","level":2,"anchor":"Flow-Customizations"},{"inlineContent":[{"type":"text","text":"You can customize the scan UI by providing a "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","isActive":true},{"type":"text","text":" in the configuration. Currently, you can set the "},{"type":"codeVoice","code":"accentColor"},{"type":"text","text":" to match your app’s design, which affects buttons and highlights throughout the scan workflow."}],"type":"paragraph"},{"text":"User Analytics","type":"heading","level":2,"anchor":"User-Analytics"},{"inlineContent":[{"type":"text","text":"The SDK supports optional correlation and telemetry:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Correlation: Pass a ","type":"text"},{"type":"codeVoice","code":"clientUserID"},{"text":" when creating your ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration"},{"text":" to associate scans with a user in your system.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Telemetry: The "},{"code":"telemetryEnabled","type":"codeVoice"},{"type":"text","text":" parameter defaults to "},{"code":"true","type":"codeVoice"},{"type":"text","text":". When enabled, the SDK sends anonymized diagnostics (for example, success and error statistics). No PII is included. Set it to "},{"code":"false","type":"codeVoice"},{"type":"text","text":" to opt out, though this reduces the diagnostic data available for troubleshooting."}]}]}]},{"text":"Support","type":"heading","level":2,"anchor":"Support"},{"inlineContent":[{"type":"text","text":"Use the latest SDK release when possible. Newer versions may include performance improvements, new features, and bug fixes."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/quadrascan\/integrationguide"]}],"references":{"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanError":{"kind":"symbol","url":"\/documentation\/quadrascan\/quadrascanerror","type":"topic","navigatorTitle":[{"kind":"identifier","text":"QuadrascanError"}],"abstract":[{"text":"Error types that may occur during a scan session.","type":"text"}],"title":"QuadrascanError","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"QuadrascanError"}],"role":"symbol","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanFlow/photoPicker":{"kind":"symbol","url":"\/documentation\/quadrascan\/quadrascanflow\/photopicker","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/photoPicker","abstract":[],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"photoPicker"}],"role":"symbol","title":"QuadrascanFlow.photoPicker","type":"topic"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanFlow/cameraCapture":{"abstract":[],"title":"QuadrascanFlow.cameraCapture","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"c