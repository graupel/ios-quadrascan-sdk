{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/quadrascan\/integrationguide"]}],"identifier":{"url":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide","interfaceLanguage":"swift"},"kind":"article","abstract":[{"text":"Integrate Quadrascan to generate 3D models and anthropometric measurements of a subject using a guided, SwiftUI-based scanning flow.","type":"text"}],"sampleCodeDownload":{"action":{"overridingTitle":"Visit","identifier":"https:\/\/github.com\/graupel\/ios-quadrascan-sdk","type":"reference","isActive":true},"kind":"sampleDownload"},"hierarchy":{"paths":[["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan"]]},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"name":"Warning","style":"warning","content":[{"inlineContent":[{"text":"This SDK is in alpha. Documentation and APIs are subject to change.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"text":"Quadrascan SDK exposes a SwiftUI view that interactively guides a person through a process that collects images of them and returns a 3D model and anthropometric measurements of said person. To use the SDK, add it to your project, provide a configuration, and present the scan view. The scan completes with a result object containing output based on your configuration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"system_overview"}],"type":"paragraph"},{"anchor":"App-Permissions","text":"App Permissions","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Quadrascan requires camera and photo library access. Add these keys to your app’s Info.plist::"}],"type":"paragraph"},{"code":["<key>NSCameraUsageDescription<\/key>","<string>Required for body scan capture<\/string>","<key>NSPhotoLibraryUsageDescription<\/key>","<string>Required for body scan capture<\/string>"],"syntax":"xml","type":"codeListing"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Both keys are required for app submission."}]}],"type":"aside"},{"anchor":"Adding-the-SDK-to-your-App","text":"Adding the SDK to your App","level":2,"type":"heading"},{"anchor":"Using-Swift-Package-Manager","text":"Using Swift Package Manager","level":3,"type":"heading"},{"inlineContent":[{"text":"Add Quadrascan to your ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["dependencies: [","    .package(url: \"https:\/\/github.com\/graupel\/ios-quadrascan-sdk.git\", .branch(\"main\"))","]"],"syntax":"swift","type":"codeListing"},{"anchor":"Manual-Installation","text":"Manual Installation","level":3,"type":"heading"},{"inlineContent":[{"text":"You can integrate the SDK manually from the GitHub Releases page.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Download the compressed zip file containing the Quadrascan-x.x.x.xcframework from (URL TBD).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Uncompress the zip file and then move the Quadrascan-x.x.x.xcframework artifact into your project folder"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Open your app’s project file in Xcode and then select your app’s target under target list"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Add Quadrascan-x.x.x.xcframework to the “Frameworks, Libraries, and Embedded Content” section in the General tab of your iOS app target, and select “Embed & Sign”"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"SDK-Initialization","text":"SDK Initialization","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Import the SDK and create a configuration:"}],"type":"paragraph"},{"code":["import Quadrascan","","let config = try QuadrascanConfiguration(teamID: \"YOUR_TEAM_ID\",","                                         meshGenerationServiceToken: \"YOUR_MESH_TOKEN\",","                                         measurementServiceToken: \"YOUR_MEASUREMENT_TOKEN\", \/\/ Required if requesting measurements","                                         requestedOutput: [.stlMesh, .measurements]) \/\/ or [.stlMesh], or [.usdzModel], or [.objMesh], or [.usdzModel, .measurements] or [.objMesh, .measurements]"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Present "},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","type":"reference","isActive":true},{"type":"text","text":" in your SwiftUI hierarchy. Handle the result in the provided closure:"}],"type":"paragraph"},{"code":["QuadrascanView(configuration: config) { response in","    \/\/ Handle session result here","}"],"syntax":"swift","type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"teamID"},{"type":"text","text":", "},{"type":"codeVoice","code":"meshGenerationServiceToken"},{"type":"text","text":", and "},{"type":"codeVoice","code":"measurementServiceToken"},{"type":"text","text":" are provided by Fitmatch."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"meshGenerationServiceToken","type":"codeVoice"},{"text":" is required for guided capture and photo picker flows.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"measurementServiceToken"},{"type":"text","text":" is required when "},{"type":"codeVoice","code":"requestedOutput"},{"type":"text","text":" includes "},{"type":"codeVoice","code":".measurements"},{"type":"text","text":", and for measurement-only flow."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set "},{"type":"codeVoice","code":"requestedOutput"},{"type":"text","text":" to specify which results you need. Use "},{"type":"codeVoice","code":"[.usdzModel, .measurements]"},{"type":"text","text":", "},{"type":"codeVoice","code":"[.stlMesh, .measurements]"},{"type":"text","text":" or "},{"type":"codeVoice","code":"[.objMesh, .measurements]"},{"type":"text","text":" to request both a 3D model and anthropometric measurements."}]}]}],"type":"unorderedList"},{"name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"The configuration initializer throws an error if required tokens are missing or invalid. It also throws an error if an invalid combination of "},{"type":"codeVoice","code":"requestedOutput"},{"type":"text","text":" is provided. An example of an invalid combination would be any combination that includes more than one 3d type output. e.g. [.stlMesh, .usdzModel], [.objMesh, .usdzModel], or [.objMesh, .stlMesh]. Only one 3D model format can be specified at a time. Wrap the initialization in a "},{"type":"codeVoice","code":"do-catch"},{"type":"text","text":" block or use "},{"type":"codeVoice","code":"try?"},{"type":"text","text":" for error handling."}],"type":"paragraph"}],"type":"aside"},{"anchor":"Optional-Configuration","text":"Optional Configuration","level":3,"type":"heading"},{"inlineContent":[{"text":"The configuration supports several optional parameters to customize the scanning experience:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"flow"}]},{"type":"text","text":": Choose the entry point for the workflow. Use "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/guidedCapture","isActive":true},{"type":"text","text":" (default) to start with AI-guided camera capture, "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/cameraCapture","isActive":true},{"type":"text","text":" to start with manual back-camera 4-pose capture, "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/photoPicker","isActive":true},{"type":"text","text":" to start with photo library selection, or "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/measurementOnly(usdzURL:heightInInches:weightInPounds:)","isActive":true},{"type":"text","text":" to start directly at measurement generation with a USDZ model."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"shouldShowWeightInput"}]},{"type":"text","text":": When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", displays a weight entry field during the flow. Defaults to "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"shouldUseImperialUnits","type":"codeVoice"}]},{"type":"text","text":": When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", uses feet\/inches and pounds throughout the UI. When "},{"type":"codeVoice","code":"false"},{"type":"text","text":" (default), uses centimeters and kilograms."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"appearance","type":"codeVoice"}]},{"text":": Customize the UI accent color with a ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","type":"reference","isActive":true},{"text":" object. Set the ","type":"text"},{"type":"codeVoice","code":"accentColor"},{"text":" to match your app’s design, which affects buttons and highlights throughout the scan workflow.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"logLevelThreshold"}]},{"type":"text","text":": Control debug logging verbosity using "},{"type":"codeVoice","code":"OSLogType"},{"type":"text","text":". Defaults to "},{"type":"codeVoice","code":".error"},{"type":"text","text":". Set to "},{"type":"codeVoice","code":".debug"},{"type":"text","text":" or "},{"type":"codeVoice","code":".info"},{"type":"text","text":" for more detailed logging during development."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"clientUserID"}],"type":"strong"},{"text":": Optional user identifier for associating scans with users in your system. Used for analytics and support purposes.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"telemetryEnabled","type":"codeVoice"}],"type":"strong"},{"text":": Controls whether anonymized diagnostic telemetry is sent. Defaults to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"On completion, the response indicates success, failure, or user cancellation."}],"type":"paragraph"},{"anchor":"Complete-Example","text":"Complete Example","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Here’s a complete example showing how to integrate Quadrascan into a SwiftUI view:"}],"type":"paragraph"},{"code":["import SwiftUI","import Quadrascan","import AVFoundation","import Photos","","struct MyView: View {","    @State private var showingScanView = false","    @State private var showingPermissionAlert = false","","    var body: some View {","        Button(\"Start Body Scan\") {","            Task {","                if await requestPermissions() {","                    showingScanView = true","                } else {","                    showingPermissionAlert = true","                }","            }","        }","        .fullScreenCover(isPresented: $showingScanView) {","            scanView","        }","        .alert(\"Permissions Required\", isPresented: $showingPermissionAlert) {","            Button(\"OK\") { }","        } message: {","            Text(\"Camera and photo library access are required for body scanning.\")","        }","    }","","    @ViewBuilder","    private var scanView: some View {","        \/\/ In production, handle configuration errors appropriately for your app","        if let config = try? QuadrascanConfiguration(teamID: \"YOUR_TEAM_ID\",","                                                     meshGenerationServiceToken: \"YOUR_MESH_TOKEN\",","                                                     measurementServiceToken: \"YOUR_MEASUREMENT_TOKEN\",","                                                     requestedOutput: [.usdzModel, .measurements],","                                                     appearance: QuadrascanAppearance(accentColor: .blue),","                                                     shouldShowWeightInput: true,","                                                     shouldUseImperialUnits: false) {","            QuadrascanView(configuration: config) { response in","                handleResponse(response)","            }","        } else {","            Text(\"Configuration error\")","        }","    }","","    private func handleResponse(_ response: QuadrascanResponse) {","        switch response {","        case .success(let result):","            print(\"Height: \\(result.heightInInches) inches, Weight: \\(result.weightInPounds, default: \"N\/A\") lbs\")","            if let measurements = result.measurementResult?.measurements {","                print(\"Received measurements: \\(measurements)\")","            }","            if let modelData = result.modelData {","                print(\"Received 3D model: \\(modelData.count) bytes\")","            }","        case .failure(let error):","            print(\"Scan failed: \\(error.localizedDescription)\")","        case .cancelled:","            break","        @unknown default:","            break","        }","        showingScanView = false","    }","","    private func requestPermissions() async -> Bool {","        let cameraAuthorized = await requestCameraAuthorization()","        let photoLibraryAuthorized = await requestPhotoLibraryAuthorization()","        return cameraAuthorized && photoLibraryAuthorized","    }","","    private func requestCameraAuthorization() async -> Bool {","        let status = AVCaptureDevice.authorizationStatus(for: .video)","        if status == .authorized { return true }","        if status == .notDetermined { return await AVCaptureDevice.requestAccess(for: .video) }","        return false","    }","","    private func requestPhotoLibraryAuthorization() async -> Bool {","        let status = PHPhotoLibrary.authorizationStatus(for: .readWrite)","        if status == .authorized || status == .limited { return true }","        if status == .notDetermined {","            let newStatus = await PHPhotoLibrary.requestAuthorization(for: .readWrite)","            return newStatus == .authorized || newStatus == .limited","        }","        return false","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Handling-Completion-and-Errors","text":"Handling Completion and Errors","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Handling the result from "},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView"},{"type":"text","text":" might look like the following:"}],"type":"paragraph"},{"code":["QuadrascanView(configuration: config) { response in","    switch response {","    case .success(let result):","        \/\/ Calibration inputs are always available","        print(\"Height: \\(result.heightInInches) inches, Weight: \\(result.weightInPounds, default: \"N\/A\") lbs\")","        if let measurements = result.measurementResult?.measurements {","            \/\/ Process measurements data","        }","        if let modelData = result.modelData {","            \/\/ Process 3D model data","        }","        \/\/ Access metadata: result.metadata","    case .failure(let error):","        switch error {","        case .captureError(let underlying):","            \/\/ Camera or capture issues occurred","        case .meshGenerationError(let underlying):","            \/\/ Mesh generation service failure","        case .meshProcessingError(let underlying):","            \/\/ Model processing failure","        case .measurementGenerationError(let underlying):","            \/\/ Measurement service failure","        case .configurationError(let underlying):","            \/\/ Invalid configuration (e.g., missing tokens)","        }","    case .cancelled:","        \/\/ User cancelled the flow","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"On ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/success(_:)","isActive":true,"type":"reference"},{"text":", handle the ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult","isActive":true,"type":"reference"},{"text":" according to your needs. It is appropriate to remove the ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","isActive":true,"type":"reference"},{"text":" from the view hierarchy at this point.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"On ","type":"text"},{"isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/cancelled","type":"reference"},{"text":" the user aborted the flow; reset your UI or state as appropriate.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On "},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/failure(_:)","isActive":true,"type":"reference"},{"type":"text","text":", handle the "},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError","isActive":true,"type":"reference"},{"type":"text","text":" value."}],"type":"paragraph"},{"anchor":"Flow-Customizations","text":"Flow Customizations","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"You can customize the scan UI by providing a "},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","isActive":true,"type":"reference"},{"type":"text","text":" in the configuration. Currently, you can set the "},{"code":"accentColor","type":"codeVoice"},{"type":"text","text":" to match your app’s design, which affects buttons and highlights throughout the scan workflow."}],"type":"paragraph"},{"anchor":"User-Analytics","text":"User Analytics","level":2,"type":"heading"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"These features are not yet implemented and are planned for a future release.","type":"text"}]}],"type":"aside"},{"inlineContent":[{"text":"The SDK supports optional correlation and telemetry:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Correlation: Pass a "},{"type":"codeVoice","code":"clientUserID"},{"type":"text","text":" when creating your "},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration"},{"type":"text","text":" to associate scans with a user in your system."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Telemetry: The "},{"type":"codeVoice","code":"telemetryEnabled"},{"type":"text","text":" parameter defaults to "},{"type":"codeVoice","code":"true"},{"type":"text","text":". When enabled, the SDK sends anonymized diagnostics (for example, success and error statistics). No PII is included. Set it to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" to opt out, though this reduces the diagnostic data available for troubleshooting."}]}]}],"type":"unorderedList"},{"anchor":"Support","text":"Support","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use the latest SDK release when possible. Newer versions may include performance improvements, new features, and bug fixes."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"platforms":[{"introducedAt":"17.0","name":"iOS","beta":false}],"modules":[{"name":"Quadrascan"}],"color":{"standardColorIdentifier":"purple"},"images":[{"identifier":"greenhand.png","type":"card"}],"title":"Integration Guide","role":"article","roleHeading":"Article"},"references":{"greenhand.png":{"variants":[{"url":"\/images\/fitmatch.ai.Quadrascan\/greenhand@2x.png","traits":["2x","light"]}],"identifier":"greenhand.png","type":"image","alt":null},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanResponse/failure(_:)":{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/failure(_:)","kind":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"failure","kind":"identifier"},{"text":"(","kind":"text"},{"text":"QuadrascanError","preciseIdentifier":"s:10Quadrascan0A5ErrorO","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol","url":"\/documentation\/quadrascan\/quadrascanresponse\/failure(_:)","abstract":[],"title":"QuadrascanResponse.failure(_:)","type":"topic"},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanError":{"title":"QuadrascanError","abstract":[{"type":"text","text":"Error types that may occur during a scan session."}],"type":"topic","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError","url":"\/documentation\/quadrascan\/quadrascanerror","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"QuadrascanError"}],"navigatorTitle":[{"kind":"identifier","text":"QuadrascanError"}],"kind":"