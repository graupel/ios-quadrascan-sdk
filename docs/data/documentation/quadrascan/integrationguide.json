{"variants":[{"paths":["\/documentation\/quadrascan\/integrationguide"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Integrate Quadrascan to generate 3D models and anthropometric measurements of a subject using a guided, SwiftUI-based scanning flow."}],"metadata":{"title":"Integration Guide","images":[{"type":"card","identifier":"greenhand.png"}],"platforms":[{"name":"iOS","beta":false,"introducedAt":"17.0"}],"color":{"standardColorIdentifier":"purple"},"roleHeading":"Article","modules":[{"name":"Quadrascan"}],"role":"article"},"hierarchy":{"paths":[["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"sampleCodeDownload":{"action":{"type":"reference","identifier":"https:\/\/github.com\/graupel\/ios-quadrascan-sdk","isActive":true,"overridingTitle":"Visit"},"kind":"sampleDownload"},"kind":"article","primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"name":"Warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This SDK is in alpha. Documentation and APIs are subject to change."}]}],"style":"warning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Quadrascan SDK exposes a SwiftUI view that interactively guides a person through a process that collects images of them and returns a 3D model and anthropometric measurements of said person. To use the SDK, add it to your project, provide a configuration, and present the scan view. The scan completes with a result object containing output based on your configuration."}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"system_overview"}]},{"anchor":"App-Permissions","type":"heading","level":2,"text":"App Permissions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Quadrascan requires camera and photo library access. Add these keys to your app’s Info.plist::"}]},{"type":"codeListing","syntax":"xml","code":["<key>NSCameraUsageDescription<\/key>","<string>Required for body scan capture<\/string>","<key>NSPhotoLibraryUsageDescription<\/key>","<string>Required for body scan capture<\/string>"]},{"name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Both keys are required for app submission."}],"type":"paragraph"}],"style":"note"},{"anchor":"Adding-the-SDK-to-your-App","type":"heading","level":2,"text":"Adding the SDK to your App"},{"anchor":"Using-Swift-Package-Manager","type":"heading","level":3,"text":"Using Swift Package Manager"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add Quadrascan to your "},{"type":"codeVoice","code":"Package.swift"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/graupel\/ios-quadrascan-sdk.git\", .branch(\"main\"))","]"]},{"type":"heading","anchor":"Manual-Installation","level":3,"text":"Manual Installation"},{"inlineContent":[{"type":"text","text":"You can integrate the SDK manually from the GitHub Releases page."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Download the compressed zip file containing the Quadrascan-x.x.x.xcframework from (URL TBD)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Uncompress the zip file and then move the Quadrascan-x.x.x.xcframework artifact into your project folder"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Open your app’s project file in Xcode and then select your app’s target under target list","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Add Quadrascan-x.x.x.xcframework to the “Frameworks, Libraries, and Embedded Content” section in the General tab of your iOS app target, and select “Embed & Sign”","type":"text"}]}]}],"type":"orderedList"},{"type":"heading","anchor":"SDK-Initialization","level":2,"text":"SDK Initialization"},{"inlineContent":[{"type":"text","text":"Import the SDK and create a configuration:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import Quadrascan","","let config = try QuadrascanConfiguration(teamID: \"YOUR_TEAM_ID\",","                                         meshGenerationServiceToken: \"YOUR_MESH_TOKEN\",","                                         measurementServiceToken: \"YOUR_MEASUREMENT_TOKEN\", \/\/ Required if requesting measurements","                                         requestedOutput: [.stlMesh, .measurements]) \/\/ or [.stlMesh], or [.usdzModel], or [.objMesh], or [.usdzModel, .measurements] or [.objMesh, .measurements]"]},{"inlineContent":[{"text":"Present ","type":"text"},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","isActive":true,"type":"reference"},{"text":" in your SwiftUI hierarchy. Handle the result in the provided closure:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["QuadrascanView(configuration: config) { response in","    \/\/ Handle session result here","}"]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"teamID"},{"type":"text","text":", "},{"type":"codeVoice","code":"meshGenerationServiceToken"},{"type":"text","text":", and "},{"type":"codeVoice","code":"measurementServiceToken"},{"text":" are provided by Fitmatch.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"meshGenerationServiceToken"},{"type":"text","text":" is required for guided capture and photo picker flows."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"measurementServiceToken"},{"type":"text","text":" is required when "},{"type":"codeVoice","code":"requestedOutput"},{"type":"text","text":" includes "},{"type":"codeVoice","code":".measurements"},{"type":"text","text":", and for measurement-only flow."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set "},{"type":"codeVoice","code":"requestedOutput"},{"type":"text","text":" to specify which results you need. Use "},{"type":"codeVoice","code":"[.usdzModel, .measurements]"},{"type":"text","text":", "},{"type":"codeVoice","code":"[.stlMesh, .measurements]"},{"type":"text","text":" or "},{"type":"codeVoice","code":"[.objMesh, .measurements]"},{"type":"text","text":" to request both a 3D model and anthropometric measurements."}]}]}],"type":"unorderedList"},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"The configuration initializer throws an error if required tokens are missing or invalid. It also throws an error if an invalid combination of ","type":"text"},{"type":"codeVoice","code":"requestedOutput"},{"text":" is provided. An example of an invalid combination would be any combination that includes more than one 3d type output. e.g. [.stlMesh, .usdzModel], [.objMesh, .usdzModel], or [.objMesh, .stlMesh]. Only one 3D model format can be specified at a time. Wrap the initialization in a ","type":"text"},{"type":"codeVoice","code":"do-catch"},{"text":" block or use ","type":"text"},{"type":"codeVoice","code":"try?"},{"text":" for error handling.","type":"text"}]}]},{"type":"heading","anchor":"Optional-Configuration","text":"Optional Configuration","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The configuration supports several optional parameters to customize the scanning experience:"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"flow","type":"codeVoice"}]},{"type":"text","text":": Choose the entry point for the workflow. Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/guidedCapture"},{"type":"text","text":" (default) to start with camera capture, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/photoPicker"},{"type":"text","text":" to start with photo library selection, or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/measurementOnly(usdzURL:heightInInches:weightInPounds:)"},{"type":"text","text":" to start directly at measurement generation with a USDZ model."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"shouldShowWeightInput"}]},{"type":"text","text":": When "},{"code":"true","type":"codeVoice"},{"type":"text","text":", displays a weight entry field during the flow. Defaults to "},{"code":"false","type":"codeVoice"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"shouldUseImperialUnits","type":"codeVoice"}]},{"type":"text","text":": When "},{"type":"codeVoice","code":"true"},{"type":"text","text":", uses feet\/inches and pounds throughout the UI. When "},{"type":"codeVoice","code":"false"},{"type":"text","text":" (default), uses centimeters and kilograms."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"appearance","type":"codeVoice"}]},{"type":"text","text":": Customize the UI accent color with a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance"},{"type":"text","text":" object. Set the "},{"type":"codeVoice","code":"accentColor"},{"type":"text","text":" to match your app’s design, which affects buttons and highlights throughout the scan workflow."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"logLevelThreshold"}]},{"type":"text","text":": Control debug logging verbosity using "},{"type":"codeVoice","code":"OSLogType"},{"type":"text","text":". Defaults to "},{"type":"codeVoice","code":".error"},{"type":"text","text":". Set to "},{"type":"codeVoice","code":".debug"},{"type":"text","text":" or "},{"type":"codeVoice","code":".info"},{"type":"text","text":" for more detailed logging during development."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"clientUserID"}],"type":"strong"},{"text":": Optional user identifier for associating scans with users in your system. Used for analytics and support purposes.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":"telemetryEnabled"}],"type":"strong"},{"text":": Controls whether anonymized diagnostic telemetry is sent. Defaults to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"On completion, the response indicates success, failure, or user cancellation."}],"type":"paragraph"},{"text":"Complete Example","level":2,"anchor":"Complete-Example","type":"heading"},{"inlineContent":[{"text":"Here’s a complete example showing how to integrate Quadrascan into a SwiftUI view:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import SwiftUI","import Quadrascan","import AVFoundation","import Photos","","struct MyView: View {","    @State private var showingScanView = false","    @State private var showingPermissionAlert = false","","    var body: some View {","        Button(\"Start Body Scan\") {","            Task {","                if await requestPermissions() {","                    showingScanView = true","                } else {","                    showingPermissionAlert = true","                }","            }","        }","        .fullScreenCover(isPresented: $showingScanView) {","            scanView","        }","        .alert(\"Permissions Required\", isPresented: $showingPermissionAlert) {","            Button(\"OK\") { }","        } message: {","            Text(\"Camera and photo library access are required for body scanning.\")","        }","    }","","    @ViewBuilder","    private var scanView: some View {","        \/\/ In production, handle configuration errors appropriately for your app","        if let config = try? QuadrascanConfiguration(teamID: \"YOUR_TEAM_ID\",","                                                     meshGenerationServiceToken: \"YOUR_MESH_TOKEN\",","                                                     measurementServiceToken: \"YOUR_MEASUREMENT_TOKEN\",","                                                     requestedOutput: [.usdzModel, .measurements],","                                                     appearance: QuadrascanAppearance(accentColor: .blue),","                                                     shouldShowWeightInput: true,","                                                     shouldUseImperialUnits: false) {","            QuadrascanView(configuration: config) { response in","                handleResponse(response)","            }","        } else {","            Text(\"Configuration error\")","        }","    }","","    private func handleResponse(_ response: QuadrascanResponse) {","        switch response {","        case .success(let result):","            print(\"Height: \\(result.heightInInches) inches, Weight: \\(result.weightInPounds, default: \"N\/A\") lbs\")","            if let measurements = result.measurementResult?.measurements {","                print(\"Received measurements: \\(measurements)\")","            }","            if let modelData = result.modelData {","                print(\"Received 3D model: \\(modelData.count) bytes\")","            }","        case .failure(let error):","            print(\"Scan failed: \\(error.localizedDescription)\")","        case .cancelled:","            break","        @unknown default:","            break","        }","        showingScanView = false","    }","","    private func requestPermissions() async -> Bool {","        let cameraAuthorized = await requestCameraAuthorization()","        let photoLibraryAuthorized = await requestPhotoLibraryAuthorization()","        return cameraAuthorized && photoLibraryAuthorized","    }","","    private func requestCameraAuthorization() async -> Bool {","        let status = AVCaptureDevice.authorizationStatus(for: .video)","        if status == .authorized { return true }","        if status == .notDetermined { return await AVCaptureDevice.requestAccess(for: .video) }","        return false","    }","","    private func requestPhotoLibraryAuthorization() async -> Bool {","        let status = PHPhotoLibrary.authorizationStatus(for: .readWrite)","        if status == .authorized || status == .limited { return true }","        if status == .notDetermined {","            let newStatus = await PHPhotoLibrary.requestAuthorization(for: .readWrite)","            return newStatus == .authorized || newStatus == .limited","        }","        return false","    }","}"],"type":"codeListing"},{"anchor":"Handling-Completion-and-Errors","level":2,"type":"heading","text":"Handling Completion and Errors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Handling the result from "},{"isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","type":"reference"},{"type":"text","text":" might look like the following:"}]},{"syntax":"swift","code":["QuadrascanView(configuration: config) { response in","    switch response {","    case .success(let result):","        \/\/ Calibration inputs are always available","        print(\"Height: \\(result.heightInInches) inches, Weight: \\(result.weightInPounds, default: \"N\/A\") lbs\")","        if let measurements = result.measurementResult?.measurements {","            \/\/ Process measurements data","        }","        if let modelData = result.modelData {","            \/\/ Process 3D model data","        }","        \/\/ Access metadata: result.metadata","    case .failure(let error):","        switch error {","        case .captureError(let underlying):","            \/\/ Camera or capture issues occurred","        case .meshGenerationError(let underlying):","            \/\/ Mesh generation service failure","        case .meshProcessingError(let underlying):","            \/\/ Model processing failure","        case .measurementGenerationError(let underlying):","            \/\/ Measurement service failure","        case .configurationError(let underlying):","            \/\/ Invalid configuration (e.g., missing tokens)","        }","    case .cancelled:","        \/\/ User cancelled the flow","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"On ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/success(_:)"},{"text":", handle the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult"},{"text":" according to your needs. It is appropriate to remove the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView"},{"text":" from the view hierarchy at this point.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/cancelled","isActive":true},{"type":"text","text":" the user aborted the flow; reset your UI or state as appropriate."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On "},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/failure(_:)"},{"type":"text","text":", handle the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError"},{"type":"text","text":" value."}]},{"anchor":"Flow-Customizations","level":2,"type":"heading","text":"Flow Customizations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can customize the scan UI by providing a "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","isActive":true},{"type":"text","text":" in the configuration. Currently, you can set the "},{"code":"accentColor","type":"codeVoice"},{"type":"text","text":" to match your app’s design, which affects buttons and highlights throughout the scan workflow."}]},{"anchor":"User-Analytics","level":2,"type":"heading","text":"User Analytics"},{"content":[{"inlineContent":[{"type":"text","text":"These features are not yet implemented and are planned for a future release."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"text","text":"The SDK supports optional correlation and telemetry:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Correlation: Pass a "},{"code":"clientUserID","type":"codeVoice"},{"type":"text","text":" when creating your "},{"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration","type":"reference","isActive":true},{"type":"text","text":" to associate scans with a user in your system."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Telemetry: The ","type":"text"},{"type":"codeVoice","code":"telemetryEnabled"},{"type":"text","text":" parameter defaults to "},{"type":"codeVoice","code":"true"},{"type":"text","text":". When enabled, the SDK sends anonymized diagnostics (for example, success and error statistics). No PII is included. Set it to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" to opt out, though this reduces the diagnostic data available for troubleshooting."}]}]}],"type":"unorderedList"},{"text":"Support","level":2,"anchor":"Support","type":"heading"},{"inlineContent":[{"text":"Use the latest SDK release when possible. Newer versions may include performance improvements, new features, and bug fixes.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide","interfaceLanguage":"swift"},"references":{"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanFlow/guidedCapture":{"url":"\/documentation\/quadrascan\/quadrascanflow\/guidedcapture","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow\/guidedCapture","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"guidedCapture","kind":"identifier"}],"title":"QuadrascanFlow.guidedCapture","abstract":[]},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanResponse/cancelled":{"url":"\/documentation\/quadrascan\/quadrascanresponse\/cancelled","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse\/cancelled","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancelled","kind":"identifier"}],"title":"QuadrascanResponse.cancelled","abstract":[]},"doc://fitmatch.ai.Quadrascan/documentation/Quadrascan/QuadrascanConfiguration":{"navigatorTitle":[{"text":"QuadrascanConfiguration","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"Configuration object used to initialize a Quadrascan session."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"QuadrascanConfiguration","kind":"identifier"}],"role":"symbol","type":"topic","url":"\/documentation\/quadrascan\/quadrascanconfiguration","title":"QuadrascanConfiguration","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration"},"https: