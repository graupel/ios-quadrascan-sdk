{"kind":"symbol","hierarchy":{"paths":[[]]},"sections":[],"identifier":{"url":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"Quadrascan"}],"title":"Quadrascan","externalID":"Quadrascan","roleHeading":"Framework","images":[{"identifier":"logo.png","type":"icon"}],"platforms":[{"introducedAt":"17.0","name":"iOS","beta":false}],"color":{"standardColorIdentifier":"purple"},"symbolKind":"module","role":"collection"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Generate 3D models and anthropometric measurements from body scans.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide"],"anchor":"Essentials","title":"Essentials"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView"],"anchor":"View","title":"View"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanOutput","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/ScanSessionContext"],"anchor":"Configuration","title":"Configuration"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult\/MeasurementResult-swift.struct","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult\/Gender","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/Measurements","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError"],"anchor":"Response","title":"Response"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"style":"warning","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"text":"This SDK is in alpha. Documentation and APIs are subject to change.","type":"text"}]}],"type":"aside"},{"inlineContent":[{"text":"Quadrascan provides a complete body scanning solution that guides users through a capture session and returns a 3D model with anthropometric measurements. The framework handles the entire scanning workflow, from camera setup to model generation, and delivers results through a simple completion handler.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The scanning process captures the user’s body from multiple angles as they rotate in place. Alternatively, users can select existing photos from their photo library showing front, left, right, and back views of the subject. The SDK processes these images on Quadrascan’s backend services and returns the generated 3D model and measurements to your app."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To integrate Quadrascan into your app, create a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration"},{"type":"text","text":" with your credentials and presentation options, then present a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView"},{"type":"text","text":" as a full-screen modal or within a navigation stack. Handle the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse"},{"type":"text","text":" in the completion closure to receive the scan results."}],"type":"paragraph"},{"level":3,"anchor":"Featured","type":"heading","text":"Featured"},{"style":"detailedGrid","type":"links","items":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/I