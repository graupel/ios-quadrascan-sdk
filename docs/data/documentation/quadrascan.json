{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[[]]},"abstract":[{"text":"Generate 3D models and anthropometric measurements from body scans.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"style":"warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This SDK is in alpha. Documentation and APIs are subject to change."}]}],"name":"Warning"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Quadrascan provides a complete body scanning solution that guides users through a capture session and returns a 3D model with anthropometric measurements. The framework handles the entire scanning workflow, from camera setup to model generation, and delivers results through a simple completion handler."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The scanning process captures the user’s body from multiple angles as they rotate in place. Alternatively, users can select existing photos from their photo library showing front, left, right, and back views of the subject. The SDK processes these images on Quadrascan’s backend services and returns the generated 3D model and measurements to your app."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To integrate Quadrascan into your app, create a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration"},{"type":"text","text":" with your credentials and presentation options, then present a "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","isActive":true},{"type":"text","text":" as a full-screen modal or within a navigation stack. Handle the "},{"type":"reference","identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse","isActive":true},{"type":"text","text":" in the completion closure to receive the scan results."}]},{"level":3,"type":"heading","text":"Featured","anchor":"Featured"},{"items":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide"],"style":"detailedGrid","type":"links"}]}],"metadata":{"modules":[{"name":"Quadrascan"}],"roleHeading":"Framework","title":"Quadrascan","platforms":[{"name":"iOS","introducedAt":"17.0","beta":false}],"externalID":"Quadrascan","color":{"standardColorIdentifier":"purple"},"symbolKind":"module","images":[{"identifier":"logo.png","type":"icon"}],"role":"collection"},"identifier":{"url":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide"],"title":"Essentials","anchor":"Essentials"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView"],"title":"View","anchor":"View"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanOutput","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow"],"title":"Configuration","anchor":"Configuration"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult\/MeasurementResult-swift.struct","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult\/Gender","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/Measurements","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError"],"anchor":"Response","title":"Response"}],"variants":[{"paths":["\/documentation\/quadrascan"],"traits":[{"interfaceLanguage":"swi