{"sections":[],"hierarchy":{"paths":[[]]},"abstract":[{"text":"Generate 3D models and anthropometric measurements from body scans.","type":"text"}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide"],"title":"Essentials","anchor":"Essentials"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView"],"title":"View","anchor":"View"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanAppearance","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanOutput","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanFlow"],"title":"Configuration","anchor":"Configuration"},{"identifiers":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult\/MeasurementResult-swift.struct","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResult\/Gender","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/Measurements","doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanError"],"title":"Response","anchor":"Response"}],"variants":[{"paths":["\/documentation\/quadrascan"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"aside","name":"Warning","style":"warning","content":[{"inlineContent":[{"type":"text","text":"This SDK is in alpha. Documentation and APIs are subject to change."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"Quadrascan provides a complete body scanning solution that guides users through a capture session and returns a 3D model with anthropometric measurements. The framework handles the entire scanning workflow, from camera setup to model generation, and delivers results through a simple completion handler.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The scanning process captures the user’s body from multiple angles as they rotate in place. Alternatively, users can select existing photos from their photo library showing front, left, right, and back views of the subject. The SDK processes these images on Quadrascan’s backend services and returns the generated 3D model and measurements to your app."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To integrate Quadrascan into your app, create a "},{"isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanConfiguration","type":"reference"},{"type":"text","text":" with your credentials and presentation options, then present a "},{"isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanView","type":"reference"},{"type":"text","text":" as a full-screen modal or within a navigation stack. Handle the "},{"isActive":true,"identifier":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/QuadrascanResponse","type":"reference"},{"type":"text","text":" in the completion closure to receive the scan results."}]},{"type":"heading","level":3,"text":"Featured","anchor":"Featured"},{"type":"links","style":"detailedGrid","items":["doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan\/IntegrationGuide"]}]}],"metadata":{"symbolKind":"module","roleHeading":"Framework","role":"collection","images":[{"identifier":"logo.png","type":"icon"}],"title":"Quadrascan","modules":[{"name":"Quadrascan"}],"externalID":"Quadrascan","platforms":[{"introducedAt":"17.0","beta":false,"name":"iOS"}],"color":{"standardColorIdentifier":"purple"}},"identifier":{"url":"doc:\/\/fitmatch.ai.Quadrascan\/documentation\/Quadrascan","interfaceLanguage":"swift"},"schemaVer